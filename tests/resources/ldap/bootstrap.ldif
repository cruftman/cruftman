############################################################################
#
# The structure of the bootstrap.ldif provide is:
#
#   dc=example,dc=org
#   + ou=people
#   | + uid=jsmith    # John Smith
#   | + uid=owilliams # Oliver Williams
#   |
#   + ou=london
#   | + ou=people
#   | | + uid=htaylor # Harry Taylor
#   | | + uid=gdavies # George Davies
#   | | + uid=jjones  # Jack Jones
#   | | + uid=mbaker  # Michael Baker
#   | |
#   + + ou=systems
#   |   + ou=configs
#   |     + cn=dhcp
#   |       + cn=dhcp-failover
#   |       + cn=london.example.org
#   |         + cn=172.22.0.0
#   |         + cn=172.22.1.0
#   |
#   + ou=manchester
#   | + ou=people
#   |   + uid=chbrown # Charlie Brown
#   |   + uid=jwilson # James Wilson


#
# dc=example,dc=org
#

dn: ou=people,dc=example,dc=org
objectClass: top
objectClass: organizationalUnit
ou: people

dn: ou=london,dc=example,dc=org
dc: london
description: Office of example.org located in London
objectclass: dcObject
objectclass: organizationalUnit
objectclass: top
ou: london

dn: ou=manchester,dc=example,dc=org
dc: manchester
description: Office of example.org located in Manchester
objectclass: dcObject
objectclass: organizationalUnit
objectclass: top
ou: manchester

#
# ou=people,dc=example,dc=org
#

dn: uid=jsmith,ou=people,dc=example,dc=org
uid: jsmith
objectClass: top
objectClass: inetOrgPerson
objectClass: mailUser
cn: John Smith
displayName: John Smith
givenName: John
sn: Smith
initials: J. S.
mail: jsmith@example.org
roomNumber: 1000
telephoneNumber: +44 0141 123 4444
userPassword: jsmith
accountStatus: enabled
enabledService: mail
enabledService: cruftman

dn: uid=owilliams,ou=people,dc=example,dc=org
uid: owilliams
objectClass: top
objectClass: inetOrgPerson
objectClass: mailUser
cn: Oliver Williams
displayName: Oliver Williams
givenName: Oliver
sn: Williams
initials: O. W
mail: owilliams@example.org
roomNumber: 1001
telephoneNumber: +44 0141 123 4444
userPassword: owilliams
accountStatus: enabled
enabledService: mail
enabledService: cruftman

#
# ou=london,dc=example,dc=org
#
#

