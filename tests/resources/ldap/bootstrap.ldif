#
# ou=systems,ou=london,dc=example,dc=org
#
dn: ou=configs,ou=systems,ou=london,dc=example,dc=org
objectclass: organizationalUnit
ou: configs

#
# ou=systems,ou=manchester,dc=example,dc=org
#

dn: ou=configs,ou=systems,ou=manchester,dc=example,dc=org
objectclass: organizationalUnit
ou: configs

#
# ou=configs,ou=systems,ou=london,dc=example,dc=org
#
dn: cn=dhcp,ou=configs,ou=systems,ou=london,dc=example,dc=org
cn: dhcp
dhcpprimarydn: cn=dhcp1.london.example.org,ou=servers,ou=systems,ou=london,dc=example,dc=org
dhcpsecondarydn: cn=dhcp2.london.example.org,ou=servers,ou=systems,ou=london,dc=example,dc=org
dhcpserverdn: cn=dhcp1.london.example.org,ou=servers,ou=systems,ou=london,dc=example,dc=org
dhcpserverdn: cn=dhcp2.london.example.org,ou=servers,ou=systems,ou=london,dc=example,dc=org
objectclass: dhcpService
objectclass: top

#
# cn=dhcp,ou=configs,ou=systems,ou=london,dc=example,dc=org
#

dn: cn=dhcp-failover,cn=dhcp,ou=configs,ou=systems,ou=london,dc=example,dc=org
cn: dhcp-failover
dhcpcomments: DHCP failover configuration for london.example.org
dhcpfailoverloadbalancetime: 3
dhcpfailoverprimaryport: 647
dhcpfailoverprimaryserver: dhcp1.london.example.org
dhcpfailoverresponsedelay: 30
dhcpfailoversecondaryport: 647
dhcpfailoversecondaryserver: dhcp2.london.example.org
dhcpfailoversplit: 128
dhcpfailoverunackedupdates: 10
dhcpmaxclientleadtime: 1800
objectclass: dhcpFailOverPeer
objectclass: top

dn: cn=london.example.org,cn=dhcp,ou=configs,ou=systems,ou=london,dc=example,dc=org
cn: london.example.org
dhcpstatements: authoritative
objectclass: top
objectclass: dhcpSharedNetwork

#
# cn=london.example.org,cn=dhcp,ou=configs,ou=systems,ou=london,dc=example,dc=org
#

dn: cn=172.22.0.0,cn=london.example.org,cn=dhcp,ou=configs,ou=systems,ou=london,dc=example,dc=org
cn: 172.22.0.0
dhcpnetmask: 24
dhcpoption: broadcast-address 172.22.0.255
dhcpoption: routers 172.22.0.254
dhcpoption: domain-name "london.example.org"
dhcpoption: domain-name-servers 8.8.8.8
dhcpoption: subnet-mask 255.255.255.0
objectclass: top
objectclass: dhcpSubnet
objectclass: dhcpOptions
objectclass: radiusprofile
radiusframedprotocol: PPP
radiusservicetype: Framed
radiustunnelmediumtype: IEEE-802
radiustunnelprivategroupid: 1000
radiustunneltype: VLAN

dn: cn=172.22.1.0,cn=london.example.org,cn=dhcp,ou=configs,ou=systems,ou=london,dc=example,dc=org
cn: 172.22.1.0
dhcpnetmask: 24
dhcpoption: broadcast-address 172.22.1.255
dhcpoption: routers 172.22.1.254
dhcpoption: domain-name "london.example.org"
