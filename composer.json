{
    "name": "cruftman/cruftman",
    "description": "Cruftman inventory software.",
    "keywords": ["cruftman", "kleptomaniac", "inventory"],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^7.2",
        "korowai/ldaplib": "dev-master",
        "laravel/lumen-framework": "^6.0",
        "dingo/api": "^2.4.0-rc1"
    },
    "require-dev": {
        "behat/behat": "^3.5",
        "behat/mink-extension": "^2.3.1",
        "behat/mink-goutte-driver": "^1.2",
        "fzaninotto/faker": "^1.4",
        "laravel/homestead": "^9.1.0",
        "mockery/mockery": "^1.0",
        "phpunit/phpunit": "^8.0",
        "psy/psysh": "dev-master"
    },
    "autoload": {
        "classmap": [
            "database/seeds",
            "database/factories"
        ],
        "psr-4": {
            "App\\": "app/",
            "Cruftman\\": "src/Cruftman/"
        }
    },
    "autoload-dev": {
        "classmap": [
            "tests/"
        ],
        "psr-4": {
          "Cruftman\\": "tests/Cruftman/",
          "Cruftman\\Docs\\Behat\\":  "docs/sphinx/Behat/"
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
