{
    "name": "cruftman/cruftman",
    "description": "Cruftman inventory software.",
    "keywords": ["cruftman", "kleptomaniac", "inventory"],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^7.2",
        "adldap2/adldap2-laravel": "^6.0",
        "fideloper/proxy": "^4.0",
        "laravel/framework": "^6.0",
        "laravel/tinker": "^1.0",
        "tymon/jwt-auth": "^1.0.0-rc.5",
        "wikimedia/composer-merge-plugin": "^1.4",
        "zircote/swagger-php": "^3.0.2"
    },
    "require-dev": {
        "behat/behat": "^3.5",
        "behat/mink-extension": "^2.3.1",
        "behat/mink-goutte-driver": "^1.2",
        "facade/ignition": "^1.4",
        "fzaninotto/faker": "^1.4",
        "laravel/homestead": "^9.1.0",
        "laravel/ui": "^1.1",
        "mockery/mockery": "^1.0",
        "nunomaduro/collision": "^3.0",
        "phpunit/phpunit": "^8.0"
    },
    "replace": {
        "cruftman/contracts": "self.version",
        "cruftman/ldap": "self.version"
    },
    "autoload": {
        "classmap": [
            "database/seeds",
            "database/factories"
        ],
        "psr-4": {
            "App\\": "app/",
            "Cruftman\\": "src/Cruftman/"
        }
    },
    "autoload-dev": {
        "psr-4": {
          "Tests\\": "tests/",
          "Cruftman\\Docs\\Behat\\":  "docs/sphinx/Behat/"
        }
    },
    "extra": {
      "merge-plugin": {
        "include": [
          "packages/*/composer.json"
        ],
        "recurse": true,
        "replace": false,
        "ignore-duplicates": false,
        "merge-dev": true,
        "merge-extra": false,
        "merge-extra-deep": false,
        "merge-extra-scripts": false
      },
      "laravel" : {
        "dont-discover": []
      }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
