{
    "name": "cruftman/constracts",
    "description": "PHP interfaces defined by cruftman",
    "keywords": ["contracts", "interfaces", "cruftman", "kleptomaniac", "inventory"],
    "license": "MIT",
    "type": "library",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=7.1.3",
        "korowai/ldaplib": "dev-master"
    },
    "require-dev": {
    },
    "autoload": {
        "psr-4": {
            "Cruftman\\Contracts\\": "src/Cruftman/Contracts/"
        },
        "exclude-from-classmap": [
          "/Tests/",
          "/Behat/",
          "/Resources/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
          "Cruftman\\Contracts\\Tests\\": "Tests/"
        }
    }
}
